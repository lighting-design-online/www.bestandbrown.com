$(function () {

  $('.fancy-image').fancybox();

  function swapimage(imageId) {

    try {
      var $mainImg = $('#img-main');
      var $zoomImgLink = $('#fancy-image');

      var thumbImgFilename = imageId + '.jpg';
      var mainImgFilename = $mainImg.attr('data-imageid') + '.jpg';

      $mainImg.attr('data-imageid', imageId);
      $mainImg.attr('src', $mainImg.attr('src').replace(mainImgFilename, thumbImgFilename));
      $zoomImgLink.attr('href', $zoomImgLink.attr('href').replace(mainImgFilename, thumbImgFilename));
      $zoomImgLink.attr('data-index', getByImageId(imageId)[0].index);
    } catch (err) {
      console.log(err);
    }
  }

  $('#image-rotator .thumbnail').click(function () {

    var $this = $(this);
    var skuId = $this.attr('data-id');

    if (skuId)
      LIGHTBASE.EVENT.changeSku(skuId);
    else
      swapimage($this.attr('data-imageid'));
  });

  $('#image-rotator').tinycarousel({
    buttons: true
  });

  $('.main-image-rotator').click(function () {

    event.preventDefault();

    // Get the main image
    var $imageMain = $('#img-main');

    // Get the data for this image
    var imageId = $imageMain.attr('data-imageid');
    var image = getByImageId(imageId)[0];

    if (image == undefined) {
      console.log('image not found ' + imageId);
      return;
    }

    // Get the new image
    var newImageId = $(this).hasClass('next') ? image.nextImageId : image.previousImageId;
    var newImage = getByImageId(newImageId)[0];

    // Change the SKU if there is one for this image
    if (newImage.skuId) {
      var skuUrl = $('body').data(newImage.skuId.toString()).url;
      var skuMaxQty = $('body').data(newImage.skuId.toString()).qty;
      LIGHTBASE.EVENT.changeSku(newImage.skuId, skuUrl, skuMaxQty);
    } else {
      var imgUrl = $imageMain.attr('src')
        .replace(imageId, newImageId)
        .substring(0, $imageMain.attr('src').indexOf('?'));
      LIGHTBASE.EVENT.swapPic(newImageId, imgUrl, newImage.alt);
    }

    // Update the main image
    var src = $imageMain.attr('src').replace(imageId, newImageId);
    $imageMain.attr('src', src);
    $imageMain.attr('data-imageid', newImageId);

    // update the link
    var $zoomImgLink = $('#fancy-image');
    $zoomImgLink.attr('data-index', newImage.index);
    var $zoomImgLinkHref = $zoomImgLink.attr('href');
    if ($zoomImgLinkHref)
      $zoomImgLink.attr('href', $zoomImgLink.attr('href').replace(imageId, newImageId));
  });


  function getByImageId(id) {
    if (imagedata) {
      return imagedata.filter(
        function (imagedata) {
          return imagedata.id === parseInt(id);
        }
      );
    }
    return null;
  };

  $(document).on('changeSku', changeSkuHandler);
  function changeSkuHandler(e) {
    var sku = $('body').data(e.skuId.toString());
    if (sku.imageId!=='')
      swapimage(sku.imageId);
  }
});;
