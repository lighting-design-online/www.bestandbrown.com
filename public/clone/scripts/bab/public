    }
  }

  const maxQty = $('#max-quantity').val();

  $('#add-to-project-quantity').spinner({
    max: maxQty || null,
    min: 1
  });

  // ADD TO BASKET BUTTONS
  function addToProjectEnabled(isEnabled, buttonText) {

    const btnAddToProject = $('#add-to-project-button');

    if (isEnabled) {
      btnAddToProject.prop('value', buttonText);
      btnAddToProject.removeAttr('disabled');
      btnAddToProject.removeClass('loading');
    } else {
      btnAddToProject.prop('value', buttonText);
      btnAddToProject.attr('disabled', 'disabled');
      btnAddToProject.addClass('loading');
    }
  }

  function showAddToProjectFeedback(isSuccess, message) {
    $.fancybox(
      message,
      {
        'width': 400,
        'height': 'auto',
        'autoSize': false,
        'autoheight': true,
        'transitionIn': 'none',
        'transitionOut': 'none'
      }
    );
  }

  function showAddToProjectErrorMessage(message) {
    const $feedbackDiv = $('#add-to-project-feedback');
    $feedbackDiv.text(message);
    $feedbackDiv.show();
  }

  function hideAddToProjectErrorMessage() {
    const $feedbackDiv = $('#add-to-project-feedback');
    $feedbackDiv.text('');
    $feedbackDiv.hide();
  }

  function errorPulse(input) {
    input.addClass('error');
    input.effect('pulsate', { times: 3 }, 1000);
  }

  $('#add-to-project-button').click(function () {

    hideAddToProjectErrorMessage();

    // Get the quantity from the input
    const $qtyInput = $('#add-to-project-quantity');
    var qty = parseInt($qtyInput.val(), 10);

    // Check positive quantity
    if (qty < 0) {
      errorPulse($qtyInput);
      showAddToProjectErrorMessage('The minimum order quantity for this product is 1');
      return false;
    }

    // Check not more than max quantity
    const maxQty = $('#add-to-project-quantity').spinner('option', 'max');
    if (maxQty && qty > maxQty) {
      showAddToProjectErrorMessage(
        `There are only ${maxQty
        } of these in stock. Please select the equivalent option from the list of alternative versions below`);
      return false;
    }

    // Get the data from the hidden input
    const $data = $('#add-to-project-data');
    const skuId = $data.attr('data-skuid');

    // Update button text
    var prevButtonText = $('#add-to-project-button').val();
    addToProjectEnabled(false, 'Adding...');

    // Remove any error styling
    $qtyInput.removeClass('error');

    // Get the SKU & project data
    const data = JSON.stringify(
      {
        Items: [
          {
            SkuId: skuId,
            Quantity: qty
          }
        ]
      });

    // Send data
    $.ajax({
      complete: function () { addToProjectEnabled(true, prevButtonText); },
      url: '/api/projects/add-sku',
      type: 'POST',
      dataType: 'json',
      data: data,
      contentType: 'application/json;charset=utf-8',
      success: function (response) {
        if (response.success) {
          // Show feedback
          let output = `<div class='add-to-project-feedback'>${qty} x ${$('.product-name-container h1').text()} added to your basket<div>`;
          output +=
            '<a href=\'javascript:parent.jQuery.fancybox.close();\' id=\'product-added-continue-shopping-link\' class=\'button close-fancybox\' >Continue shopping</a>';
          output +=
            '<a href=\'/project\' id=\'product-added-view-project-link\' class=\'primary button\'>View basket</a></div></div>';
          //output += '<a href=\'/checkout/\' id=\'product-added-checkout-link\' class=\'begin-checkout button secondary\'>Check out</a></div>';
          showAddToProjectFeedback(true, output, null);

          // Reset form
          $('input[name=qty]').each(function () {
            $(this).val('1');
          });

          // raise project changed event
          LIGHTBASE.EVENT.updateProjectTotal(response.project.subTotal, response.project.lines.length);
        } else {
          showAddToProjectErrorMessage(response.errorMessages[0]);
        }
      },
      error: function () {
        showAddToProjectErrorMessage(
          'There was a problem adding your item. Please check the quantity and try again.');
      }
    });

    return false;
  });

  $('.close-fancybox').click(function () {
    $.fancybox.close();
  });

  $('#change-zone-button').click(function () {
    $('#select-zone-container').toggle();
  });

  function showHideAddZoneFeedback(show, message, success) {
    const divAddZoneFeedback = $('#add-zone-feedback');
    divAddZoneFeedback.html(message);
    if (success) {
      divAddZoneFeedback.addClass('success');
    } else {
      divAddZoneFeedback.addClass('failure');
    }
    if (show) {
      divAddZoneFeedback.show();
    } else {
      divAddZoneFeedback.hide();
    }
  }

  function addZone() {

    const $addZoneButton = $('#add-zone-button');
    $addZoneButton.addClass('loading');

    // validate form
    var zoneName = $('#add-zone-name').val();
    if (zoneName === '') {
      showHideAddZoneFeedback(true, 'You must enter a name', false);
      $('#add-zone-name').focus();
      $addZoneButton.removeClass('loading');
      return;
    }

    const formData = new FormData();
    formData.append('ZoneName', zoneName);
    $.ajax({
      url: '/api/projects/add-zone',
      type: 'POST',
      dataType: 'json',
      data: formData,
      processData: false,
      contentType: false,
      success: function (data) {
        if (data.success) {
          changeZone(data.newZoneId, zoneName);
          closeAddZoneModal();
        } else {
          const errorMessage = 'Unable to add zone, please reload the page and try again';
          showHideAddZoneFeedback(true, errorMessage, false);
        }
      },
      error: function (request, status, error) {
        alert('Unable to add zone, please reload the page and try again');
      }
    });
  }

  function addZoneEnter(e) {

    if (e.which !== 13)
      return true;

    $(this).blur();
    $('#add-zone-button').focus().click();
    event.preventDefault();
    return false;
  }

  $('#modal-add-zone').dialog({
    autoOpen: false,
    height: 100,
    width: 300,
    autoscale: true,
    padding: 20,
    modal: true,
    buttons: {
      'add-zone-button': {
        text: 'Add Zone',
        id: 'add-zone-button',
        'class': 'button primary',
        click: function () {
          addZone();
        }
      },
      Cancel: function () {
        closeAddZoneModal();
        showHideAddZoneFeedback(false, '', true);
      }
    },
    open: function () {
      $('#add-zone-name').keypress(addZoneEnter);
    },
    close: function () {
      closeAddZoneModal();
    }
  });

  function closeAddZoneModal() {
    $('#add-zone-name').val('');
    showHideAddZoneFeedback(false, '', true);
    modalAddZone.dialog('close');
  }

  function changeZone(zoneId, zoneName) {

    const data = JSON.stringify({ ZoneId: zoneId });

    $.ajax({
      beforeSend: function () { addToProjectEnabled(false, 'Changing zone...'); },
      url: '/api/projects/update-preferred-project-zone',
      type: 'POST',
      dataType: 'json',
      data: data,
      contentType: 'application/json;charset=utf-8',
      statusCode: {
        200: function (result) {
          $('#add-to-project-button').prop('value', `Add to ${zoneName}`);
          $('#add-to-project-data').data('zoneid', zoneId);
          $('#select-zone-container').hide();
          addToProjectEnabled(true);
        },
        500: function () {
          showAddToProjectFeedback(false, 'There was a  problem adding your item. Please contact support.');
        }
      }
    });
  }

  $('#add-to-project-container').on('click',
    '.select-zone',
    function () {

      // hide the drop down
      $('.select-zone-container').hide();

      // Get the zone details
      const $this = $(this)[0];
      const zoneId = $this.dataset.zoneid;
      const zoneName = $this.textContent;

      // If zone exists then change to it
      if (zoneId !== '-1') {
        changeZone(zoneId, zoneName);
      } else $('#modal-add-zone').dialog('open');
    });

  $('#lead-times-more').hover(
    function () {
      $('#lead-times-additional').show();
    }, function () {
      $('#lead-times-additional').hide();
    }
  );

});;
