$(function () {

  if($.fn.editable)
    $.fn.editable.defaults.mode = 'inline';

  $('.zone-name.editable').editable();

  // FEEDBACK

  function showFeedback(isError, message) {
    var $feedbackDiv = $('#basket-feedback');
    $feedbackDiv.text(message);
    $feedbackDiv.show();
  }

  function clearFeedback() {

    var $feedbackDiv = $('#basket-feedback');
    $feedbackDiv.text('');
    $feedbackDiv.hide();

    var $editFeedbackDiv = $('#edit-feedback');
    $editFeedbackDiv.text('');
    $editFeedbackDiv.hide();
  }

  function showEditFeedback(message) {
    var $feedbackDiv = $('#edit-feedback');
    $feedbackDiv.text(message);
    $feedbackDiv.show();

    $('.loading').removeClass('loading');
    LIGHTBASE.Events.modalOpen();
  }

  // EDIT BASKET

  function updateBasketEnabled(enabled, currentlyUpdating, checkoutInitiated) {

    // Toggle the create order buttons
    var aCheckOut = $('#checkout');
    updateButton(aCheckOut, enabled, checkoutInitiated, checkoutInitiated ? 'Preparing order...' : 'Order now');

    // Toggle the update basket button
    var btnUpdateProject = $('.update-project-button');
    updateButton(btnUpdateProject, enabled, currentlyUpdating, currentlyUpdating ? 'Updating...' : 'Update');

  }

  function updateButton(button, enabled, processing, text) {

    button.enabled = enabled;

    // Update the text on the update button
    if (button.is('a')) button.text(text);
    else button.prop('value', text);

    // Show icon on button if clicked
    if (processing) { button.addClass('loading'); }
    else { button.removeClass('loading'); }
  }

  function updateBasket() {

    clearFeedback();
    updateBasketEnabled(false, true, false);

    var errors = new Array();
    var lines = new Array();

    // Loop through all of the qty boxes
    $('.line-row:visible').each(function () {

      var $this = $(this);
      var txtQty = $this.find('.line-quantity');

      // Check the box is not empty
      if (txtQty.val()) {

        var qty = txtQty.val();

        // Check the quantity is an integer
        if (qty.IsNotPositiveInteger()) {
          errors[errors.length] = '"' + qty + '" is not a valid quantity, it must be a whole number.<br />';
        }

        // If no errors then add item to our list
        if (errors.length === 0) {
          var line = {};
          line.lineId = txtQty.data('lineid');
          line.qty = qty;
          lines.push(line);
        }
      }
      else {
        // Not all products have a quantity 
        // insert a message at the top of the error list if it not already there
        if (errors[0] && errors[0] !== 'You must enter a quantity for each product') {
          errors.splice(0, 0, 'You must enter a quantity for each product');
        }
      }
    });

    if (errors.length !== 0) {
      // We had errors
      showFeedback(false, errors.toString());
    }
    else {

      var basket = JSON.stringify({ Lines: lines });

      $.ajax({
        complete: function () { updateBasketEnabled(true); },
        url: '/api/projects/patch',
        type: 'POST',
        dataType: 'json',
        data: basket,
        contentType: 'application/json;charset=utf-8',
        success: function (data) {
          LIGHTBASE.EVENT.projectUpdated(data.project);
          if (!data.success) {
            showFeedback(false, data.errorMessages.toString());
          }
        }
      });
    }

    return false;
  }

  function updateBasketWithPricing() {

    clearFeedback();
    updateBasketEnabled(false, true, false);

    var errors = new Array();
    var lines = new Array();
    var vatCoefficient = $('#hid-vat-coefficient').val();

    // Loop through all of the qty boxes
    $('.line-row').each(function () {

      var $this = $(this);
      var txtQty = $this.find('.line-quantity');
      var txtOverridePrice = $this.find('.override-price');

      // Check the box is not empty
      if (txtQty.val()) {

        var qty = txtQty.val();

        // Check the quantity is an integer
        if (qty.IsNotPositiveInteger()) {
          errors[errors.length] = '"' + qty + '" is not a valid quantity, it must be a whole number.<br />';
        }

        var priceExVat = null;
        if (txtOverridePrice.val())
          priceExVat = txtOverridePrice.val() / vatCoefficient;

        // If no errors then add item to our list
        if (errors.length === 0) {
          var line = {};
          line.lineId = txtQty.data('lineid');
          line.qty = qty;
          line.overridePrice = priceExVat;
          lines.push(line);
        }
      }
      else {
        // Not all products have a quantity 
        // insert a message at the top of the error list if it not already there
        if (errors[0] && errors[0] !== 'You must enter a quantity for each product') {
          errors.splice(0, 0, 'You must enter a quantity for each product');
        }
      }
    });

    if (errors.length !== 0) {
      // We had errors
      showFeedback(false, errors.toString());
    }
    else {
      var qName = $('#project-name').val();
      var qDesc = $('#project-description').val();

      var shippingNote = $('#shipping-note-input').val();
      var txtShippingOverride = $('input[name=shipping]');
      var shippingOverride = null;
      if (txtShippingOverride.val())
        shippingOverride = (txtShippingOverride.val() / vatCoefficient).toFixed(2);

      var basket = JSON.stringify({ Lines: lines, ProjectName: qName, ProjectDescription: qDesc, ShippingOverride: shippingOverride, ShippingNote: shippingNote });

      $.ajax({
        //beforeSend: function () { updateBasketEnabled(false); },
        complete: function () { updateBasketEnabled(true); },
        url: '/api/projects/patch-custom-pricing',
        type: 'POST',
        dataType: 'json',
        data: basket,
        contentType: 'application/json;charset=utf-8',
        success: function (data) {
