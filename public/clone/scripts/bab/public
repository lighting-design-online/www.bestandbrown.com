$(document).ready(function() {

  $(document).on('changeSku', changeSkuHandler);

  function changeSkuHandler(e) {

    // Get the selected SKU
    var skuId = e.skuId;
    var sku = $('body').data(skuId.toString());

    // Update the main price
    var selectedPriceContainer = $('.todays-price');
    var selectedPriceValue = $('#selected-price-value');
    selectedPriceValue.text(sku.currentPrice);
    if (sku.currentPrice === 'POA') {
      selectedPriceContainer.addClass('poa');
    } else {
      selectedPriceContainer.removeClass('poa');
    }

    if (sku.hasDiscount === 'True') {
      $('.no-discount').addClass('has-discount').removeClass('no-discount');
    } else {
      $('.has-discount').addClass('no-discount').removeClass('has-discount');
    }

    // Update the saving summary
    var savingContainer = $('.saving');
    var rrpValue = $('#rrp-value');
    var savingValue = $('#saving-value');
    var savingPercentage = $('#saving-percentage-value');

    if (sku.standardPrice === '' || sku.standardPrice === sku.currentPrice) {
      savingContainer.hide();
    } else {
      savingContainer.show();
      savingValue.text($.trim(sku.savingAmount));
      savingValue.show();
      savingPercentage.text($.trim(sku.savingPercentage));
      savingPercentage.show();
      rrpValue.text($.trim(sku.standardPrice));
      rrpValue.show();
    }

    // Update the clearance/overstock sections
