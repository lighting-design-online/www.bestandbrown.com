$(document).ready(function() {

  // ADD TO BASKET BUTTON
  $('#submit-question').click(function() {

    var errors = new Array();

    // Check the form is valid
    var emailAddress = $('#email-address').val();
    if (emailAddress == undefined || emailAddress === '') {
      errors[errors.length] = 'Please enter your email address so that we can reply to your question.';
    } else if (emailAddress.indexOf('@') < 0 || emailAddress.indexOf('.') < 0) {
      errors[errors.length] = 'Please check your email address.';
    }

    if (errors.length !== 0) {
      // We had errors
      showFeedback(false, errors.toString());
      return false;
    }

    var data = JSON.stringify({
      SenderName: $('#customer-name').val(),
      SenderEmailAddress: emailAddress,
      Message: $('#question').val(),
      ProductCode: $('#product-code').val()
    });

    $.ajax({
      beforeSend: function() { sendEnabled(false); },
      complete: function() { sendEnabled(true); },
      url: '/api/contact/ask-question',
      type: 'POST',
      dataType: 'json',
      data: data,
      contentType: 'application/json;charset=utf-8',
      statusCode: {
        200: function (response) {
          if (response.Success)
            showFeedback(true, 'Thank you for your question. We\'ll get back you within one working day');
          else
            showFeedback(false, 'There was a problem sending your message. Please try our live chat');
          $('#ask-question-form').hide();
        },
        500: function() {
          showFeedback(false, 'There was a problem sending your message. Please try our live chat.');
        }
      }
    });

    return false;
  });

  function sendEnabled(yes) {

    var btnSend = $('#submit-question');

    if (yes) {
      btnSend.prop('value', 'Send Email')
        .enabled = true
        .addClass('loading');

    } else {
      btnSend.prop('value', 'Sending...')
        .enabled = false
        .removeClass('loading');
    }
  }

  function showFeedback(isSuccess, message) {

    var feedbackDiv = $('#ask-question-feedback');

    // Show the div with the message
    feedbackDiv
      .show()
      .html(message)
      .removeClass();

    feedbackDiv.addClass(isSuccess ? 'success' : 'error');

    parent.$.fancybox.update();
  }
});;
