String.prototype.IsPositiveInteger = function () {
    return $.isNumeric(this) && Math.floor(this) == this && this > 0;
}

String.prototype.IsNotPositiveInteger = function () {
    return !this.IsPositiveInteger();
}

// CHECK IF STRING IS NULL OR WHITESPACE
function isBlank(input) {
    if (input == null) return true;
    return input.replace(/\s/g, '').length < 1;
}

function highlightError(input, message) {
    if (input) {
        var $parent = input.closest('.field-wrapper');
        $parent.addClass('has-error');
        $parent.children('.help-block').addClass('error').text(message);
    }
}

function highlightErrorCleave(input, message) {
    if (input) {
        var $parent = input.parentElement.parentElement;

        if ($parent.classList)
            $parent.classList.add('has-error');

        for (var i = 0; i < $parent.childNodes.length; i++) {
            var $helpBlock = $parent.childNodes[i];
            if ($helpBlock.classList && $helpBlock.classList.contains('help-block')) {
                $helpBlock.classList.add('error');
                $helpBlock.innerHTML = message;
                break;
            }
        }
    }
}

function checkRequiredFields(elementId) {

    var errors = 0;

    $(elementId).find('input[type=text]').each(function () {
        var $this = $(this);
        if ($this.prop('required') && !$this.val()) {
            highlightError($this, 'Required');
            errors++;
        }
    });

    $(elementId).find('select').each(function () {
        var $this = $(this);
        if ($this.prop('required') && $this.prop('selectedIndex') === 0) {
            highlightError($this, 'Required');
            errors++;
        }
    });

    return errors;
};
